# Anthropic API key — powers note extraction and per-criterion eligibility reasoning.
# Get one at https://console.anthropic.com. Copy this file to .env.local and fill it in.
# In production, set this in Vercel → Project → Settings → Environment Variables.
ANTHROPIC_API_KEY=

# ClinicalTrials.gov API v2 needs NO key — it's public. Nothing to configure.
